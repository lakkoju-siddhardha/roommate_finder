<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RoommateFinder · Dashboard</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href="/dashboard.css" />
</head>
<body>

  <div class="app-shell">

    <!-- ===================== SIDEBAR ===================== -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-logo">
        <span class="logo-mark">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <circle cx="14" cy="14" r="12" stroke="url(#logoGrad)" stroke-width="2"/>
            <circle cx="14" cy="14" r="4" fill="url(#logoGrad)"/>
            <defs>
              <linearGradient id="logoGrad" x1="0" y1="0" x2="28" y2="28">
                <stop offset="0" stop-color="#00F5FF"/>
                <stop offset="1" stop-color="#7C3AED"/>
              </linearGradient>
            </defs>
          </svg>
        </span>
        <span class="logo-text">Roommate<em>Finder</em></span>
      </div>

      <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-item active" data-tooltip="Dashboard">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="8" height="8" rx="2"/><rect x="13" y="3" width="8" height="5" rx="2"/><rect x="13" y="12" width="8" height="9" rx="2"/><rect x="3" y="14" width="8" height="7" rx="2"/></svg>
          <span>Dashboard</span>
        </a>
       
      
       
        
      </nav>

      <div class="sidebar-footer">
        <a href="/logout" class="nav-item logout" data-tooltip="Logout">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M15 3h3.5A2.5 2.5 0 0 1 21 5.5v13a2.5 2.5 0 0 1-2.5 2.5H15"/><path d="M10 17l5-5-5-5M15 12H3"/></svg>
          <span>Logout</span>
        </a>
      </div>
    </aside>

    <!-- ===================== MAIN ===================== -->
    <div class="main-wrap">

      <!-- ===================== TOP NAVBAR ===================== -->
      <header class="navbar">
        <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>

        <div class="navbar-brand">
          <svg width="24" height="24" viewBox="0 0 28 28" fill="none">
            <circle cx="14" cy="14" r="12" stroke="url(#logoGrad2)" stroke-width="2"/>
            <circle cx="14" cy="14" r="4" fill="url(#logoGrad2)"/>
            <defs>
              <linearGradient id="logoGrad2" x1="0" y1="0" x2="28" y2="28">
                <stop offset="0" stop-color="#00F5FF"/>
                <stop offset="1" stop-color="#7C3AED"/>
              </linearGradient>
            </defs>
          </svg>
          <span>Roommate<em>Finder</em></span>
        </div>

        

        <div class="navbar-actions">
          <button class="icon-btn" id="notifBtn" aria-label="Notifications">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 9a6 6 0 1 1 12 0c0 4 1.5 5.5 1.5 5.5H4.5S6 13 6 9Z"/><path d="M10 19a2 2 0 0 0 4 0"/></svg>
            <span class="ping"></span>
          </button>

          <div class="user-profile" id="userProfile">
            <div class="avatar">
    <%= user.name.charAt(0).toUpperCase() %>
</div>
            <div class="user-meta">
            <span class="user-name"><%= user.name %></span>
            <span class="user-role">Hosteller</span>
            </div>
            <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </div>
        </div>
      </header>

      <!-- ===================== CONTENT ===================== -->
      <main class="content">

        <div class="content-head">
          <div>
            <h1>Welcome back, <span class="grad-text"><%= user.name %></span></h1>
            <p class="subtext">View your hostel details and connect with your roommates.</p>
          </div>
          <div class="refresh-note">
    Keep your hostel details up to date. Refresh to sync with SRM.
</div>

          <button class="btn-primary" onclick="openRefresh()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
            Refresh SRM Data
          </button>
        </div>

        <!-- ===================== STAT CARDS ===================== -->
        <section class="stat-grid">

         <section class="roommates-card glass">

    <div class="card-header">
        <div>
            <h2>👥 My Roommates</h2>
            <p>Students sharing your room</p>
        </div>

        <span class="room-count">
            <%= roommates ? roommates.length : 0 %> Roommates
        </span>
    </div>

   <% if (roommates.length === 0) { %>

<div class="empty-roommates">
    <h3>No roommates found yet</h3>
    <p>Your roommates haven't logged into Roommate Finder yet. <a href="https://roommate-finder-zgkj.onrender.com">srmaproommatefinder</a></p>
</div>

<% } else { %>

    <% roommates.forEach(roommate => { %>

   <div class="roommate-item">

    <div class="roommate-info">

        <h3 class="roommate-name">
            <%= roommate.name %>
        </h3>

        <p class="roommate-branch">
            <%= roommate.branch
                .replace("B.Tech.-", "")
                .replace("[UG - Full Time]", "")
                .trim() %>
        </p>

    </div>

    <button class="chat-btn">
     <a href="/chat/<%= roommate.reg_no %>" class="chat-btn">
    💬 Chat
</a>
    </button>

</div>

    <% }) %>

<% } %>

         </section>
         
          <article class="stat-card glass" style="--accent:#00F5FF">
    <div class="stat-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M3 10.5 12 4l9 6.5"/>
            <path d="M5 9.5V19a1 1 0 0 0 1 1h4v-5h4v5h4a1 1 0 0 0 1-1V9.5"/>
        </svg>
    </div>

    <div class="stat-body">

        <span class="stat-label">
            Hostel Details
        </span>

        <span class="stat-value">
            <%= user.room_type %>
        </span>

        <div class="hostel-info">

            <div class="info-row">
                <span>Block</span>
                <strong><%= user.block_name %></strong>
            </div>

            <div class="info-row">
                <span>Tower</span>
                <strong><%= user.tower %></strong>
            </div>

            <div class="info-row">
                <span>Room</span>
                <strong><%= user.room_number %></strong>
            </div>

        </div>

    </div>
         </article>

          <article class="stat-card glass" style="--accent:#7C3AED">
            <div class="stat-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="4" y="4" width="16" height="16" rx="3"/><path d="M4 9.5h16M9 4v16"/></svg>
            </div>
            <div class="stat-body">
              <span class="stat-label"><%= user.academic_year %></span>
              <span class="stat-value">Allotted Date</span>
              <span class="stat-sub"><%= user.allotted_date %></span>
            </div>
          </article>

          <article class="stat-card glass" style="--accent:#34D399">
            <div class="stat-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M8.5 12.5l2.3 2.3L16 10"/></svg>
            </div>
            <div class="stat-body">
              <span class="stat-label">Hostel  Status</span>
              <span class="stat-value"><% if(user.room_number){ %>

Hosteller

<% } else { %>

Not Yet Allotted

<% } %></span>
              
            </div>
          </article>

          <!-- ===================== MY ROOMMATES ===================== -->



          

        </section>

       

        <!-- ===================== RECENT ACTIVITY ===================== -->
       

      </main>
    </div>
  </div>
   <div class="refresh-modal" id="refreshModal">

    <div class="refresh-box">

        <h2>Refresh SRM Data</h2>

        <p>Enter your SRM password to sync latest hostel details.</p>

        <form action="/refresh" method="POST">

            <input
                type="password"
                name="password"
                placeholder="SRM Password"
                required>

            <div class="refresh-buttons">

                <button type="submit">
                    Refresh
                </button>

                <button
                    type="button"
                    onclick="closeRefresh()">

                    Cancel

                </button>

            </div>

        </form>

    </div>

</div>
<div class="notification-popup" id="notificationPopup">

    <div class="notification-header">
        <h3>Notifications</h3>
    </div>

    <div class="notification-empty">

        <div class="notification-icon">🔔</div>

        <h4>No new notifications</h4>

        <p>
            We'll notify you when:
        </p>

        <ul>
            <li>💬 You receive a new message</li>
            <li>🏠 A roommate joins your room</li>
            <li>🔄 Hostel details are updated</li>
        </ul>

    </div>

</div>

</div>
<div class="profile-popup" id="profilePopup">

    <div class="profile-top">

        <div class="profile-avatar">
            <%= user.name.charAt(0).toUpperCase() %>
        </div>

        <h3><%= user.name %></h3>

    </div>

    <div class="profile-details">

        <div class="detail-row">

            <div class="detail-icon">🆔</div>

            <div class="detail-text">
                <%= user.reg_no %>
            </div>

        </div>

        <div class="detail-row">

            <div class="detail-icon">🎂</div>

            <div class="detail-text">
                <%= new Date(user.dob).toLocaleDateString("en-GB", {
                    day: "2-digit",
                    month: "short",
                    year: "numeric"
                }) %>
            </div>

        </div>

        <div class="detail-row">

            <div class="detail-icon">👤</div>

            <div class="detail-text">
                <%= user.gender %>
            </div>

        </div>

        <div class="detail-row">

            <div class="detail-icon">🎓</div>

            <div class="detail-text">
                <%= user.branch %>
            </div>

        </div>

        <div class="detail-row">

            <div class="detail-icon">📚</div>

            <div class="detail-text">
                <%= user.semester %>
            </div>

        </div>

    </div>

    <hr>

    <a href="/logout" class="profile-logout">
        Logout
    </a>

</div>
<div class="drawer-overlay" id="drawerOverlay"></div>
  <script src="/dashboard.js"></script>
</body>
</html>
