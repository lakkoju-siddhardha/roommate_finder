<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>RoomSync</title>

<link rel="stylesheet" href="/loading.css">

</head>

<body>

<div class="loader-container">

    <div class="logo">
        Room<span>Sync</span>
    </div>

    <div class="spinner"></div>

    <h2><%= title %></h2>

    <p><%= description %></p>

</div>

<form
    id="loadingForm"
    action="<%= action %>"
    method="POST"
    style="display:none;">
</form>

<script>

setTimeout(() => {

    document.getElementById("loadingForm").submit();

}, 600);

</script>

</body>

</html>